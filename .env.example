# Copy this file to .env and fill in your real values.
# Never commit .env — it's gitignored.

# Port the API listens on (defaults to 3000 if unset)
PORT=3000

# MongoDB connection string (from MongoDB Atlas)
# Example: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/velocity?retryWrites=true&w=majority
MONGODB_URI=
